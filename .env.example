# ============================================================
# FinTrack — Environment Variables Template
# Copier ce fichier en .env et remplir les valeurs
# .env est dans .gitignore — NE JAMAIS committer .env
# ============================================================

# ------------------------------------------------------------
# PostgreSQL — auth-service
# ------------------------------------------------------------
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_NAME=fintrack_auth
AUTH_DB_USERNAME=
AUTH_DB_PASSWORD=

# ------------------------------------------------------------
# PostgreSQL — transaction-service
# ------------------------------------------------------------
TX_DB_HOST=localhost
TX_DB_PORT=5432
TX_DB_NAME=fintrack_transactions
TX_DB_USERNAME=
TX_DB_PASSWORD=

# ------------------------------------------------------------
# PostgreSQL — budget-service
# ------------------------------------------------------------
BUDGET_DB_HOST=localhost
BUDGET_DB_PORT=5432
BUDGET_DB_NAME=fintrack_budgets
BUDGET_DB_USERNAME=
BUDGET_DB_PASSWORD=

# ------------------------------------------------------------
# PostgreSQL — report-service
# ------------------------------------------------------------
REPORT_DB_HOST=localhost
REPORT_DB_PORT=5432
REPORT_DB_NAME=fintrack_reports
REPORT_DB_USERNAME=
REPORT_DB_PASSWORD=

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ------------------------------------------------------------
# Kafka
# ------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ------------------------------------------------------------
# JWT
# ------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000

# ------------------------------------------------------------
# Email (SMTP)
# ------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ------------------------------------------------------------
# Exchange Rate API
# ------------------------------------------------------------
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://openexchangerates.org/api

# ------------------------------------------------------------
# Monitoring
# ------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
