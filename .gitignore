# ============================================================
# FinTrack Monorepo - .gitignore
# Java + Spring Boot + Angular + Docker + IDE
# ============================================================

# ------------------------------------------------------------
# JAVA / MAVEN
# ------------------------------------------------------------
target/
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# Maven wrapper
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ------------------------------------------------------------
# SPRING BOOT
# ------------------------------------------------------------
*.pid
spring-shell.log

# ------------------------------------------------------------
# ANGULAR / NODE
# ------------------------------------------------------------
frontend/**/node_modules/
frontend/**/.angular/
frontend/**/dist/
frontend/**/.cache/
frontend/**/*.js.map
frontend/**/npm-debug.log*
frontend/**/yarn-debug.log*
frontend/**/yarn-error.log*

# ------------------------------------------------------------
# ENVIRONMENT & SECRETS — JAMAIS sur Git
# ------------------------------------------------------------
.env
.env.*
!.env.example
*.env
application-local.yml
application-local.properties
application-secrets.yml
**/src/main/resources/application-local.yml
**/src/main/resources/application-local.properties

# ------------------------------------------------------------
# DOCKER
# ------------------------------------------------------------
infrastructure/docker/volumes/
infrastructure/docker/data/

# ------------------------------------------------------------
# IDEs
# ------------------------------------------------------------
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
bin/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ------------------------------------------------------------
# OS
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# LOGS & REPORTS
# ------------------------------------------------------------
logs/
*.log
jacoco.exec
/target/site/jacoco/

# ------------------------------------------------------------
# KUBERNETES SECRETS (générés localement)
# ------------------------------------------------------------
infrastructure/k8s/secrets/
infrastructure/k8s/**/*-secret.yaml
